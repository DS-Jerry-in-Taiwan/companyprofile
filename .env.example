APP_ENV=development
APP_PORT=8000

# External services
GOOGLE_API_KEY=
SERPER_API_KEY=

# Optional protection for API endpoint
X_API_KEY=

# 搜尋模型配置（可選，預設在 config/search_config.json 中設定）
# SEARCH_GEMINI_MODEL=gemini-2.0-flash-lite
# SEARCH_GEMINI_TEMPERATURE=0.2

# LLM Provider 配置（由 config/llm_config.json 控制，以下環境變數可覆蓋）
# LLM_PROVIDER=gemini        # gemini 或 bedrock（覆蓋 config/llm_config.json 的 provider）
# GEMINI_MODEL=gemini-2.5-flash    # 覆蓋 config 中 gemini.model
# BEDROCK_MODEL=nova-lite          # 覆蓋 config 中 bedrock.model（nova-micro/nova-lite/nova-pro）